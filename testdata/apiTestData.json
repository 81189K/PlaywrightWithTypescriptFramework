{
    "GET_ALL": {
        "request":{
            "resource": "/booking"
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK",
            "headerContentType": "application/json; charset=utf-8"
        }
    },
    "GET_ID": {
        "request":{
            "resource": "/booking",
            "ID":1
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "createBooking": {
        "request":{
            "resource": "/booking",
            "headers": {
                "Accept": "application/json",
                "Content-Type": "application/json"
            },
            "payload": {
                "firstname": "Jim",
                "lastname": "Son",
                "totalprice": 111,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "updateBooking": {
        "request":{
            "resource": "/booking/1",
            "headers": {
                "Accept": "application/json",
                "Content-Type": "application/json",
                "Authorization": "Basic YWRtaW46cGFzc3dvcmQxMjM=" 
            },
            "payload": {
                "firstname": "Jim",
                "lastname": "Smith",
                "totalprice": 111,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "createAuthToken": {
        "request":{
            "resource": "auth",
            "headers": {
                "Content-Type": "application/json"
            },
            "payload": {
                "username": "{{apiUsername}}",
                "password": "{{apiPassword}}"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "updateBooking2": {
        "request":{
            "resource": "/booking/1",
            "headers": {
                "Accept": "application/json",
                "Content-Type": "application/json",
                "Cookie": "token={{authToken}}" 
            },
            "payload": {
                "firstname": "Will",
                "lastname": "Jackson",
                "totalprice": 11111,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    }
}