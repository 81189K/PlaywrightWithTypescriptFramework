{
    "GET_ALL": {
        "request":{
            "resource": "/booking"
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK",
            "headerContentType": "application/json; charset=utf-8"
        }
    },
    "GET_ID": {
        "request":{
            "resource": "/booking",
            "ID":1
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "createBooking": {
        "request":{
            "resource": "/booking",
            "headers": {
                "Accept": "application/json",
                "Content-Type": "application/json"
            },
            "payload": {
                "firstname": "Jim",
                "lastname": "Son",
                "totalprice": 111,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    }
}