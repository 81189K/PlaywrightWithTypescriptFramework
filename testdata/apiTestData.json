{
    "GET": {
        "request":{
            "resource": "/booking"
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK",
            "headerContentType": "application/json; charset=utf-8"
        }
    },
    "createBooking": {
        "request":{
            "resource": "/booking",
            "payload": {
                "firstname": "Jim",
                "lastname": "Son",
                "totalprice": 111,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "updateBooking": {
        "request":{
            "resource": "/booking",
            "headers": {
                "Authorization": "Basic YWRtaW46cGFzc3dvcmQxMjM=" 
            },
            "payload": {
                "firstname": "Jim",
                "lastname": "Smith",
                "totalprice": 222,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "createAuthToken": {
        "request":{
            "resource": "auth",
            "payload": {
                "username": "{{apiUsername}}",
                "password": "{{apiPassword}}"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "updateBooking2": {
        "request":{
            "resource": "/booking",
            "headers": {
                "Cookie": "token={{authToken}}" 
            },
            "payload": {
                "firstname": "Will",
                "lastname": "Jackson",
                "totalprice": 333,
                "depositpaid": true,
                "bookingdates": {
                    "checkin": "2026-07-01",
                    "checkout": "2026-07-07"
                },
                "additionalneeds": "Breakfast"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "patchBooking": {
        "request":{
            "resource": "/booking",
            "headers": {
                "Cookie": "token={{authToken}}" 
            },
            "payload": {
                "firstname": "James",
                "lastname": "Brown"
            }
        },
        "response":{
            "statusCode": 200,
            "statusText": "OK"
        }
    },
    "deleteBooking": {
        "request":{
            "resource": "/booking/{{ID}}",
            "headers": {
                "Cookie": "token={{authToken}}" 
            }
        },
        "response":{
            "statusCode": 201,
            "statusText": "Created"
        }
    },
    "verifyDeletion": {
        "statusCode": 404,
        "statusText": "Not Found"
    }
}